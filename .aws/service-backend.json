{
  "cluster": "<FRONTEND_CLUSTER_NAME>",
  "serviceName": "playerledger-backend",
  "taskDefinition": "igs-backend",
  "desiredCount": 1,
  "launchType": "FARGATE",
  "platformVersion": "LATEST",
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": ["<SUBNET_ID>"],
      "securityGroups": ["<BACKEND_SG>"],
      "assignPublicIp": "ENABLED"
    }
  },
  "serviceConnectConfiguration": {
    "enabled": true,
    "namespace": "playerledger.local",
    "services": [
      {
        "portName": "http",
        "discoveryName": "backend",
        "clientAliases": [
          { "port": 8080, "dnsName": "backend" }
        ]
      }
    ]
  }
}
