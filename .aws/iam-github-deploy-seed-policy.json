{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunSeedTask",
      "Effect": "Allow",
      "Action": "ecs:RunTask",
      "Resource": "arn:aws:ecs:ap-southeast-2:160900807326:task-definition/igs-backend:*",
      "Condition": {
        "ArnEquals": {
          "ecs:cluster": "arn:aws:ecs:ap-southeast-2:160900807326:cluster/warmhearted-crocodile-18gqvo-jko-cluster"
        }
      }
    },
    {
      "Sid": "DescribeSeedTask",
      "Effect": "Allow",
      "Action": "ecs:DescribeTasks",
      "Resource": "arn:aws:ecs:ap-southeast-2:160900807326:task/warmhearted-crocodile-18gqvo-jko-cluster/*"
    },
    {
      "Sid": "PassEcsRolesToTasks",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::160900807326:role/jko_ecs",
      "Condition": {
        "StringEquals": { "iam:PassedToService": "ecs-tasks.amazonaws.com" }
      }
    }
  ]
}
</content>
