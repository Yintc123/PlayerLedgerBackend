{
  "family": "igs-backend",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/jko_ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "volumes": [
    { "name": "tmp" }
  ],
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "REGISTRY/igs_backend:LATEST",
      "essential": true,
      "user": "65532:65532",
      "readonlyRootFilesystem": true,
      "stopTimeout": 30,
      "linuxParameters": {
        "initProcessEnabled": false,
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 4096,
          "hardLimit": 8192
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "tmp",
          "containerPath": "/tmp"
        }
      ],
      "portMappings": [
        {
          "name": "http",
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "APP_ENV", "value": "staging" },
        { "name": "PORT", "value": "8080" },
        { "name": "GIN_MODE", "value": "release" },
        { "name": "ALLOWED_ORIGINS", "value": "http://igs-frontend-alb-1031231573.ap-southeast-2.elb.amazonaws.com" },
        { "name": "ALLOW_CREDENTIALS", "value": "true" },
        { "name": "DB_HOST", "value": "EC2_PRIVATE_IP" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USER", "value": "jko_vm" },
        { "name": "DB_NAME", "value": "playerledger" },
        { "name": "DB_SSLMODE", "value": "disable" },
        { "name": "REDIS_HOST", "value": "EC2_PRIVATE_IP" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "REDIS_DB", "value": "0" },
        { "name": "LOG_LEVEL", "value": "info" },
        { "name": "LOG_FORMAT", "value": "json" },
        { "name": "LOG_SERVICE", "value": "playerledger" },
        { "name": "RATE_LIMIT_ENABLED", "value": "true" },
        { "name": "RATE_LIMIT_IP_PERIOD", "value": "60" },
        { "name": "RATE_LIMIT_IP_MAX", "value": "60" },
        { "name": "RATE_LIMIT_USER_PERIOD", "value": "60" },
        { "name": "RATE_LIMIT_USER_MAX", "value": "300" },
        { "name": "METRICS_ENABLED", "value": "true" },
        { "name": "METRICS_PATH", "value": "/metrics" },
        { "name": "JWT_ISSUER", "value": "playerledger" },
        { "name": "JWT_ACCESS_TTL", "value": "900" },
        { "name": "JWT_GRACE_WINDOW", "value": "10" },
        { "name": "JWT_CLOCK_SKEW_LEEWAY", "value": "30" },
        { "name": "BCRYPT_COST", "value": "12" },
        { "name": "ADMIN_USERNAME", "value": "admin" }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:jko_vm_pg_redis_1:POSTGRES_PASSWORD::"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:jko_vm_pg_redis_1:REDIS_PASSWORD::"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:jko_vm_pg_redis_1:JWT_ACCESS_SECRET::"
        },
        {
          "name": "JWT_REFRESH_SECRET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:jko_vm_pg_redis_1:JWT_REFRESH_SECRET::"
        },
        {
          "name": "ADMIN_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:jko_vm_pg_redis_1:ADMIN_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/igs-backend",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Project",
      "value": "PlayerLedger"
    },
    {
      "key": "Component",
      "value": "Backend"
    }
  ]
}
