# =============================================================
# PlayerLedger Backend — 環境變數範例
# 對應規格：docs/specs/infrastructure.md §4.2 / §4.3
# 複製此檔為 .env 並填入實際值；.env 不得提交版控
# =============================================================

# =============================================================
# App Environment
# =============================================================
APP_ENV=dev                               # dev | staging | prod；決定載入哪份 config.yaml

# =============================================================
# Server Configuration
# =============================================================
PORT=8080
GIN_MODE=release                          # debug | release | test；prod 必須 release
ALLOWED_ORIGINS=http://localhost:3000     # 逗號分隔多個來源；ALLOW_CREDENTIALS=true 時不可為 *
ALLOW_CREDENTIALS=true
TRUSTED_PROXIES=                          # 逗號分隔 CIDR；空 = 完全不信任 proxy header
SHUTDOWN_TIMEOUT=10                       # graceful shutdown 超時（秒）
READ_HEADER_TIMEOUT=10                    # 防 Slowloris attack（秒）
READ_TIMEOUT=30
WRITE_TIMEOUT=30
IDLE_TIMEOUT=120
MAX_REQUEST_BODY=1048576                  # bytes，預設 1MB

# =============================================================
# Database — PostgreSQL（§6）
# =============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=playerledger
DB_SSLMODE=disable                        # disable | require | verify-ca | verify-full；prod 必須 require 以上（§6.1）
DB_MAX_OPEN_CONNS=25                      # 連線池最大開啟連線數
DB_MAX_IDLE_CONNS=5                       # 連線池最大閒置連線數
DB_CONN_MAX_LIFETIME=300                  # 連線復用上限（秒）
DB_CONNECT_TIMEOUT=5                      # PG connect_timeout；防 hang（秒）
DB_STATEMENT_TIMEOUT=10                   # 單 statement 上限；防慢查打爆連線池（秒）
DB_PREPARE_STMT=true                      # 直連 PG=true；PgBouncer transaction mode=false（§6.1）

# =============================================================
# Redis（§7）
# =============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                           # 無密碼留空
REDIS_DB=0                                # 建議 auth 用 Redis 獨立 DB 或獨立 instance（§7.1 maxmemory-policy noeviction）
REDIS_DIAL_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_POOL_SIZE=10

# =============================================================
# JWT — 對應 ADR 007 / docs/specs/infrastructure.md §8 / §4.2
# =============================================================
# 演算法：HS256（當前單體服務；多服務化後升級 RS256）
# 兩組 secret 獨立且必須 ≥32 字元；production 使用隨機高強度字串

JWT_ISSUER=playerledger                                # 寫入 iss claim，驗證時必須相符

# Access token secret（純 stateless，15 分鐘短效）
JWT_SECRET=your-access-secret-min-32-characters-here
JWT_SECRET_PREVIOUS=                                   # 上一把 secret；rotation grace 期間用於 fallback（空 = 無 grace）
                                                       # 若設定：長度 ≥32、不等於主 secret（v1.9 起 config validate 強制）

# Refresh token secret（每次 rotation 換新 jti）
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-here
JWT_REFRESH_SECRET_PREVIOUS=                           # 上一把 refresh secret；同上規則

# Token TTL 與容忍度（單位：秒）
JWT_ACCESS_TTL=900                                    # access token 有效期；15 分鐘
JWT_GRACE_WINDOW=10                                   # refresh rotation grace 窗口（網路重試容忍，§8.2.1）
JWT_CLOCK_SKEW_LEEWAY=30                              # 時鐘漂移容忍（多副本部署必備，§4.2）

# Client 政策（不同 client 套不同 TTL；見 §4.2 ClientPolicy 定義）
#
# Shell 環境變數不允許 "." 或 "-"，故命名為全大寫 + 底線：
#   "cms-web"      → JWT_CLIENT_POLICIES_CMS_WEB_*
#   "public-web"   → JWT_CLIENT_POLICIES_PUBLIC_WEB_*
#   "ios-app"      → JWT_CLIENT_POLICIES_IOS_APP_*
#   "android-app"  → JWT_CLIENT_POLICIES_ANDROID_APP_*
# Viper 內部轉換後，map key 仍為原始 client_id（cms-web / ios-app …）
# ABSOLUTE_TTL 必須 > REFRESH_TTL（family 絕對壽命不因 rotation 延長）
#
JWT_CLIENT_POLICIES_CMS_WEB_REFRESH_TTL=3600          # CMS 人員 refresh TTL；1 小時
JWT_CLIENT_POLICIES_CMS_WEB_ABSOLUTE_TTL=28800        # CMS 人員 session 絕對上限；8 小時
JWT_CLIENT_POLICIES_PUBLIC_WEB_REFRESH_TTL=3600       # 公開網頁；1 小時
JWT_CLIENT_POLICIES_PUBLIC_WEB_ABSOLUTE_TTL=86400     # 24 小時
JWT_CLIENT_POLICIES_IOS_APP_REFRESH_TTL=2592000       # 30 天（行動 app 裝置）
JWT_CLIENT_POLICIES_IOS_APP_ABSOLUTE_TTL=15552000     # 180 天
JWT_CLIENT_POLICIES_ANDROID_APP_REFRESH_TTL=2592000
JWT_CLIENT_POLICIES_ANDROID_APP_ABSOLUTE_TTL=15552000

BCRYPT_COST=12                                         # 密碼雜湊 bcrypt cost，10-15；2026 推薦 12

# =============================================================
# Logging（§5）
# =============================================================
LOG_LEVEL=info                            # debug | info | warn | error
LOG_FORMAT=json                           # json | console（JSON 為生產推薦）
LOG_SERVICE=playerledger                  # 注入每筆日誌的 service 欄位
LOG_AUDIT_PATH=                           # 空 = audit 共用 stdout；非空 = 寫入檔案（詳見 §18.3.1）
                                          # 建議 production 設為 /var/log/playerledger/audit.log

# =============================================================
# Rate Limiting（§15）
# =============================================================
# 兩層獨立限流：
#   外層 IP：所有人都受限，擋濫用與暴力破解
#   內層 User：登入後改用 user key，避免共享 IP 誤傷（NAT、辦公室）
#
RATE_LIMIT_ENABLED=true                   # 全局開關
RATE_LIMIT_IP_PERIOD=60                   # IP 層時間窗口（秒）
RATE_LIMIT_IP_MAX=60                      # IP 層單位時間內請求上限
RATE_LIMIT_USER_PERIOD=60                 # User 層時間窗口（秒）
RATE_LIMIT_USER_MAX=300                   # User 層額度可寬鬆（避免共享 IP 問題）

# =============================================================
# Metrics（§18）
# =============================================================
# /metrics 端點無 auth、無限流；必由網路層隔離（k8s NetworkPolicy / reverse proxy）
# 暴露 Prometheus 指標與 build info，攻擊者免費取得 endpoint inventory
#
METRICS_ENABLED=true
METRICS_PATH=/metrics                     # Prometheus scrape 路徑

# =============================================================
# Super Admin Seed（取代規格 §13.5 原 SQL seed migration）
# =============================================================
# 啟動時 idempotent 確保 admin 帳號存在：
#   - 帳號不存在 → bcrypt(ADMIN_PASSWORD) → 建立（role=admin）
#   - 帳號已存在 → 跳過（不主動覆寫密碼，避免無聲改密碼造成稽核盲點）
#
# 規則：
#   - 兩欄同時留空 → 跳過 seed（dev 預設）
#   - 任一非空 → 兩個都必填、密碼長度 ≥ 12
#   - APP_ENV=prod 必填（config validate 強制）
#
# 旋密：要改密碼請走 CMS API 或 ops 手動 update，不要直接改這裡再重啟（不會生效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-min-12-chars-strong-pw
